# Secrets live in ".env.local" (same folder as package.json) — never commit that file.
# Setup:  npm run env:init   then   npm run env:edit   (or edit env.local.template in Cursor)
# Required for Prisma + MySQL (see docs/MYSQL_WORKBENCH.md — includes password help).

# With a password (replace YOUR_PASSWORD):
# DATABASE_URL="mysql://root:YOUR_PASSWORD@127.0.0.1:3306/sft_lms"

# XAMPP / empty root password (note root:@ with nothing between : and @):
# DATABASE_URL="mysql://root:@127.0.0.1:3306/sft_lms"

# Cloud (add TLS params per provider):
# DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE?sslaccept=strict"

# Zoom Server-to-Server OAuth (Admin → Tutor Led → create meeting & sync recordings)
# https://marketplace.zoom.us/ → Develop → you will see 4 app types — pick ONLY:
#   "Server-to-Server OAuth" (NOT General App, SDK, or Webhook Only)
# Then add scopes: meeting:write:admin, meeting:read:admin, recording:read:admin, cloud_recording:read:admin
# Copy Account ID, Client ID, Client Secret from the app’s App Credentials tab.
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_HOST_USER_ID=your-zoom-user-id-or-email
# ZOOM_AUTO_RECORD_CLOUD=true
