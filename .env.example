# Copy to ".env.local" for Next.js (never commit real secrets).
# Required for Prisma + MySQL (see docs/MYSQL_WORKBENCH.md — includes password help).

# With a password (replace YOUR_PASSWORD):
# DATABASE_URL="mysql://root:YOUR_PASSWORD@127.0.0.1:3306/sft_lms"

# XAMPP / empty root password (note root:@ with nothing between : and @):
# DATABASE_URL="mysql://root:@127.0.0.1:3306/sft_lms"

# Cloud (add TLS params per provider):
# DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE?sslaccept=strict"
