# Copy to .env.local in this folder (same folder as package.json).
# From terminal in project root:  npm run env:init
# Then edit .env.local with Notepad or:  npm run env:edit

# --- MySQL (required) ---
DATABASE_URL="mysql://root:YOUR_PASSWORD@127.0.0.1:3306/sft_lms"

# --- Zoom Server-to-Server OAuth (optional) ---
# https://marketplace.zoom.us → Develop → Server-to-Server OAuth
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_HOST_USER_ID=
ZOOM_AUTO_RECORD_CLOUD=true
